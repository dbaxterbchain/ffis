---
import LotusMotif from './LotusMotif.astro';

interface Props {
  text: string;
  author: string;
}

const { text, author } = Astro.props;
---

<aside class="pullquote">
  <LotusMotif class="pullquote__lotus" stroke={2.5} center={false} />
  <div class="container pullquote__inner">
    <p class="pullquote__text">&ldquo;{text}&rdquo;</p>
    <p class="pullquote__author">{author}</p>
  </div>
</aside>

<style>
  .pullquote {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: var(--grad-hero);
    color: #fff;
    padding-block: var(--space-9);
  }
  .pullquote :global(.pullquote__lotus) {
    position: absolute;
    z-index: -1;
    top: 50%;
    left: -8%;
    width: min(40vh, 380px);
    color: #fff;
    opacity: 0.08;
    transform: translateY(-50%);
  }
  .pullquote__inner {
    text-align: center;
    max-width: 52rem;
  }
  .pullquote__text {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-style: italic;
    font-weight: 500;
    font-size: var(--fs-quote);
    line-height: 1.3;
    text-wrap: balance;
  }
  .pullquote__author {
    margin-top: var(--space-5);
    font-size: var(--fs-sm);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
  }
</style>
