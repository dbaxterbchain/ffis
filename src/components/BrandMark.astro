---
/**
 * Brand lockup: official lotus mark + wordmark. The wordmark inherits `color`
 * (currentColor) so the header can flip it light/dark by scroll state; the
 * lotus is the fixed multicolor mark and reads on both light and dark.
 */
interface Props {
  href?: string | null;
  class?: string;
}

const { href = '/', class: className } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  class:list={['brand', className]}
  href={href ?? undefined}
  aria-label="Foundation for Innovation in Society — home"
>
  <img class="brand__mark" src="/logo-lotus.png" alt="" width="320" height="172" />
  <span class="brand__text" aria-hidden="true">
    <span class="brand__kicker">Foundation for</span>
    <span class="brand__name">Innovation in Society</span>
  </span>
</Tag>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: inherit;
    text-decoration: none;
    line-height: 1;
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand__mark {
    display: block;
    width: 3.25rem;
    height: auto;
    flex: none;
  }
  .brand__text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .brand__kicker {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.85;
  }
  .brand__name {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 600;
    font-size: 1.4rem;
    letter-spacing: -0.01em;
  }
</style>
