---
/**
 * Donate call-to-action. Defaults to `site.donateUrl` so the general donate
 * destination lives in one place (swap to the every.org URL at launch). Pass
 * `href` to point a specific button elsewhere (e.g. the pay-it-forward board).
 */
import Button from './Button.astro';
import { site } from '../config/site';

interface Props {
  size?: 'md' | 'lg';
  variant?: 'gold' | 'primary' | 'ghost';
  label?: string;
  href?: string;
  class?: string;
}

const {
  size = 'md',
  variant = 'gold',
  label = 'Donate',
  href,
  class: className,
} = Astro.props;

const url = href ?? site.donateUrl;
// An explicit href is treated as an external link; otherwise defer to config.
const external = href ? true : site.donateIsExternal;
const attrs = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<Button
  href={url}
  variant={variant}
  size={size}
  class={className}
  {...attrs}
>
  {label}
</Button>
