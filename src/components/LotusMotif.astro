---
/**
 * Decorative lotus watermark (the brand motif), drawn from the official logo.
 * Purely decorative -> aria-hidden. It's a white silhouette; callers control
 * its size and opacity via the passed class (it's typically faded over the
 * brand gradient).
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<img class={className} src="/lotus-watermark.png" alt="" aria-hidden="true" />

<style>
  img {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
