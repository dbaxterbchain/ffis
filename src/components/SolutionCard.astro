---
import type { FoodSolution } from '../data/foodSolutions';

type Props = FoodSolution & { class?: string };

const { title, detail, refModel, class: className } = Astro.props;
---

<article class:list={['solution', className]}>
  <span class="solution__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 18h6M10 21h4M12 3a6 6 0 0 0-4 10.5c.7.7 1 1.3 1 2.5h6c0-1.2.3-1.8 1-2.5A6 6 0 0 0 12 3z"></path>
    </svg>
  </span>
  <h3 class="solution__title">{title}</h3>
  <p class="solution__detail">{detail}</p>
  {
    refModel && (
      <p class="solution__tag">
        <span class="solution__tag-label">Proven model</span>
        {refModel}
      </p>
    )
  }
</article>

<style>
  .solution {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }
  .solution__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-md);
    color: #fff;
    background: var(--grad-accent);
    box-shadow: var(--shadow-sm);
    margin-bottom: var(--space-4);
  }
  .solution__icon svg {
    width: 1.6rem;
    height: 1.6rem;
  }
  .solution__title {
    font-size: var(--fs-h3);
    margin-bottom: var(--space-3);
  }
  .solution__detail {
    color: var(--color-text-muted);
    line-height: var(--lh-snug);
    font-size: var(--fs-sm);
  }
  .solution__tag {
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--color-primary-strong);
  }
  .solution__tag-label {
    display: block;
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.15rem;
  }
</style>
