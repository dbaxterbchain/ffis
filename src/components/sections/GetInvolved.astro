---
import ProjectSection from '../ProjectSection.astro';
import SectionHeading from '../SectionHeading.astro';
import DonateCTA from '../DonateCTA.astro';
import ContactCTA from '../ContactCTA.astro';
import InvolvementForm from '../InvolvementForm.astro';
---

<ProjectSection id="get-involved" labelledby="gi-title">
  <SectionHeading
    align="center"
    kicker="Get involved"
    titleId="gi-title"
    title="Help build a more resilient community"
  >
    <p>
      The work of the Foundation depends on people who show up — as donors,
      volunteers, restaurants, and partners.
    </p>
  </SectionHeading>

  <div class="gi__grid">
    <DonateCTA
      kicker="For donors"
      title="Pay a meal forward"
      text="Your gift puts a healthy meal in the hands of someone who needs it — and fuels the Foundation's wider work on food resilience."
      label="Donate a Meal"
      href="https://pifboard.com/donate"
      note="The Foundation for Innovation in Society is a registered 501(c)(3) nonprofit. Donations are tax-deductible to the extent allowed by law."
    />

    <div class="gi__contact">
      <ContactCTA
        title="Volunteer or partner with us"
        text="Restaurants, distribution partners, and out-of-the-box thinkers — we'd love to hear from you."
        buttonLabel="Email the team"
      />
      <ContactCTA
        title="Bring a project to your city"
        text="Want to adapt these models where you live? Start a conversation with us."
        buttonLabel="Reach out"
      />
    </div>
  </div>

  <div class="gi__form">
    <InvolvementForm />
  </div>
</ProjectSection>

<style>
  .gi__grid {
    display: grid;
    gap: var(--space-5);
    margin-top: var(--space-8);
  }
  .gi__contact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }
  .gi__form {
    margin-top: var(--space-8);
    max-width: 640px;
    margin-inline: auto;
  }

  @media (max-width: 760px) {
    .gi__contact {
      grid-template-columns: 1fr;
    }
  }
</style>
